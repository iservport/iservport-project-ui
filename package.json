{
  "name": "project-ui",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "start:dev:https": "ng serve --host 0.0.0.0 --port 4200 --ssl true --ssl-cert ~/.certs/dev-cert.pem --ssl-key ~/.certs/dev-key.pem --proxy-config proxy.conf.dev.json",
    "start:aws": "ng serve --host 0.0.0.0 --port 4200 --ssl true --ssl-cert %USERPROFILE%/.certs/dev-cert.pem --ssl-key %USERPROFILE%/.certs/dev-key.pem --proxy-config proxy.conf.aws.json",
    "start:aws:https": "ng serve --host 0.0.0.0 --port 4200 --ssl true --ssl-cert ~/.certs/dev-cert.pem --ssl-key ~/.certs/dev-key.pem --proxy-config proxy.conf.aws.json",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "setup": "yarn install && yarn build"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "yarn@1.22.19",
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "^21.2.3",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@fontsource-variable/nunito-sans": "^5.2.7",
    "@iservport/iservport-angular-ui": "8.8.798",
    "@ngneat/overview": "^7.0.0",
    "@ngxpert/hot-toast": "^6.1.0",
    "bootstrap": "^5.3.8",
    "flatpickr": "^4.6.13",
    "ngx-cookie-service": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
